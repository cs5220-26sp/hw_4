// Row reduction test — PE wrapper
//
// Each PE has n_reductions input vectors in send_buf.
// f_reduce() runs the full reduction; results_per_pe result vectors
// land in this PE's result buffer via get_result_dsd().

param memcpy_params: comptime_struct;
param reduce_params: comptime_struct;
param kernel_x_dim: i16;
param extent: i16;
param results_per_pe: i16;

const sys_mod = @import_module("<memcpy/memcpy>", memcpy_params);

const n_reductions: i16 = results_per_pe * kernel_x_dim;

fn on_done() void { sys_mod.unblock_cmd_stream(); }

// Result DSD provider: advances through result buffer
var result_idx: i16 = 0;
var result_base_dsd = @get_dsd(mem1d_dsd, .{
    .tensor_access = |i|{extent} -> result[i],
});

fn get_result_dsd() mem1d_dsd {
    const dsd = @increment_dsd_offset(result_base_dsd, result_idx * extent, f32);
    result_idx += 1;
    return dsd;
}

const red = @import_module("pe.csl", .{
    .reduce_params = reduce_params,
    .extent = extent,
    .results_per_pe = results_per_pe,
    .f_get_result_dsd = get_result_dsd,
    .f_done = on_done,
});

var send_buf: [n_reductions * extent]f32 = @zeros([n_reductions * extent]f32);
var result:   [results_per_pe * extent]f32 = @zeros([results_per_pe * extent]f32);
var ptr_send_buf: [*]f32 = &send_buf;
var ptr_result:   [*]f32 = &result;

var send_base_dsd = @get_dsd(mem1d_dsd, .{
    .tensor_access = |i|{extent} -> send_buf[i],
});

fn f_reduce() void {
    result_idx = 0;
    red.start();
    var r: i16 = 0;
    while (r < n_reductions) {
        const data_dsd = @increment_dsd_offset(send_base_dsd, r * extent, f32);
        red.reduce(data_dsd);
        r += 1;
    }
}

comptime {
    @comptime_assert(@is_arch("wse2"));
    red.init();
    @export_symbol(ptr_send_buf, "send_buf");
    @export_symbol(ptr_result, "result");
    @export_symbol(f_reduce);
}
