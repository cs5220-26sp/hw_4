// Column broadcast test — PE wrapper
//
// Imports broadcast/pe.csl via the broadcast_params comptime_struct
// generated by broadcast/layout.csl.

param memcpy_params: comptime_struct;
param broadcast_params: comptime_struct;
param kernel_y_dim: i16;
param N_per_pe: i16;

const sys_mod = @import_module("<memcpy/memcpy>", memcpy_params);

fn on_done() void { sys_mod.unblock_cmd_stream(); }

const bcast = @import_module("pe.csl", .{
    .broadcast_params = broadcast_params,
    .f_activate = on_chunk_received,
    .f_done = on_done,
});

var send_buf: [N_per_pe]f32 = @zeros([N_per_pe]f32);
var result: [N_per_pe * kernel_y_dim]f32 = @zeros([N_per_pe * kernel_y_dim]f32);
var ptr_send_buf: [*]f32 = &send_buf;
var ptr_result:   [*]f32 = &result;

// Test activation callback: stores each received wavelet into result buffer
var recv_idx: i16 = 0;
fn on_chunk_received(data: f32) void {
    result[recv_idx] = data;
    recv_idx += 1;
}

fn f_broadcast() void {
    const send_dsd = @get_dsd(mem1d_dsd, .{ .tensor_access = |i|{N_per_pe} -> send_buf[i] });
    bcast.broadcast_start(send_dsd);
}

comptime {
    @comptime_assert(@is_arch("wse2"));
    bcast.init();
    @export_symbol(ptr_send_buf, "send_buf");
    @export_symbol(ptr_result, "result");
    @export_symbol(f_broadcast);
}
